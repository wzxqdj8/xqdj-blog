{
  "version": 2,
  "build": {
    "env": {
      "PHP_VERSION": "8.3"
    }
  },
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.9.0",
      "memory": 2048,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}